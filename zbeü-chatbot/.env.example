# Environment Variables Template
# Kendi değerlerinizle doldurun ve dosya adını .env olarak değiştirin

# Google Gemini API Key (zorunlu)
# API Key almak için: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Web Scraping URL (opsiyonel - varsayılan değer kodda tanımlı)
SCRAPE_URL=https://ogrenci.beun.edu.tr/duyurular.html

# Not: Go uygulaması .env dosyasını otomatik okumaz
# Environment variable'ları manuel olarak set etmeniz gerekir:
#
# Windows (PowerShell):
#   $env:GEMINI_API_KEY="your-api-key-here"
#
# Windows (CMD):
#   set GEMINI_API_KEY=your-api-key-here
#
# Linux/Mac:
#   export GEMINI_API_KEY=your-api-key-here
